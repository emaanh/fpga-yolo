TD_tb_top.dump_cells ;
    %vpi_func 3 57 "$fopen" 32, v0xb050a26c0_0, "w" {0 0 0};
    %store/vec4 v0xb05159400_0, 0, 32;
    %load/vec4 v0xb05159400_0;
    %cmpi/e 0, 0, 32;
    %jmp/0xz  T_0.0, 4;
    %vpi_call/w 3 59 "$display", "[tb] ERROR: cannot open %0s", v0xb050a26c0_0 {0 0 0};
    %vpi_call/w 3 60 "$finish" {0 0 0};
T_0.0 ;
    %vpi_call/w 3 62 "$fwrite", v0xb05159400_0, "# %0d rows, layout c*H*W + gy*W + gx ", P_0xb050c65c0 {0 0 0};
    %vpi_call/w 3 63 "$fwrite", v0xb05159400_0, "(c=0..6 -> tx,ty,tw,th,obj,cls0,cls1; H=W=%0d)\012", 32'sb00000000000000000000000000000100 {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0xb051595e0_0, 0, 32;
T_0.2 ; Top of for-loop
    %load/vec4 v0xb051595e0_0;
    %pad/s 97;
    %cmpi/s 112, 0, 97;
	  %jmp/0xz T_0.3, 5;
    %load/vec4 v0xb051595e0_0;
    %parti/s 13, 0, 2;
    %store/vec4 v0xb051590e0_0, 0, 13;
    %delay 1000, 0;
    %vpi_call/w 3 67 "$fwrite", v0xb05159400_0, "%04x\012", v0xb05159180_0 {0 0 0};
T_0.4 ; for-loop step statement
    %load/vec4 v0xb051595e0_0;
    %addi 1, 0, 32;
    %store/vec4 v0xb051595e0_0, 0, 32;
    %jmp T_0.2;
T_0.3 ; for-loop exit label
    %vpi_call/w 3 69 "$fclose", v0xb05159400_0 {0 0 0};
    %end;
